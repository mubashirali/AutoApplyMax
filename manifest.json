{
  "manifest_version": 3,
  "name": "AutoApplyMax",
  "version": "2.3.1",
  "description": "Autofill job applications on any site with a powerful heuristic engine.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.icims.com/jobs/*", "*://*.icims.com/connect/*"],
      "js": ["content-icims.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "autofill-engine/vendor/string-similarity.js",
        "autofill-engine/ai-service.js",
        "autofill-engine/FormFiller.js",
        "autofill-engine/HeuristicParser.js",
        "autofill-engine/adapters/WorkdayAdapter.js",
        "autofill-engine/AutofillOrchestrator.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
